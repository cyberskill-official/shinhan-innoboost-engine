{
  "name": "shinhan-innoboost-engine",
  "version": "0.0.1",
  "description": "Shinhan Global Innoboost 2026 — chat-with-data engine + HITL + vibe-coding kit (PoC)",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev": "turbo run dev",
    "containerise": "turbo run containerise",
    "eval": "turbo run eval",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@types/node": "25.6.0",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "turbo": "2.9.7",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "subject-case": [
        0
      ],
      "scope-empty": [
        0
      ]
    }
  }
}